# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration (PostgreSQL must be running; e.g. docker-compose up -d postgres)
# On Windows, prefer 127.0.0.1 if you see ECONNREFUSED on ::1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=educycle
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# Redis Configuration (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookie Configuration
COOKIE_SECRET=change-me-to-a-secure-random-string-in-production

# CORS Configuration (comma-separated for multiple origins; used for CSRF allowed origins)
CORS_ORIGIN=http://localhost:3000

# Production: set strong secrets (required when NODE_ENV=production)
# JWT_SECRET and COOKIE_SECRET must not be the default value in production.

# Optional: protect /metrics in production (query param ?key=METRICS_API_KEY)
# METRICS_API_KEY=your-metrics-secret

# File Upload Configuration
MAX_FILE_SIZE=10485760

# AWS S3 Configuration (required)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_CDN_URL=https://your-cloudfront-url.cloudfront.net

# Google Maps API Configuration (optional, for geocoding and place search)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
