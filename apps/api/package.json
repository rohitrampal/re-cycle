{
  "name": "@recycle/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "db:migrate": "tsx -r dotenv/config src/database/migrate.ts",
    "db:generate": "node -r dotenv/config dist/database/generate-migration.js",
    "docs:serve": "node docs/serve-docs.cjs"
  },
  "dependencies": {
    "fastify-plugin": "^4.5.1",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@fastify/cookie": "^9.1.1",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "i18next": "^23.7.6",
    "i18next-fs-backend": "^2.3.0",
    "ioredis": "^5.3.2",
    "isomorphic-dompurify": "^2.9.0",
    "nanoid": "^5.0.4",
    "pg": "^8.11.3",
    "postgis": "^1.0.6",
    "sharp": "^0.33.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "pino-pretty": "^10.2.3",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-ui-serve": "^0.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
